{
  "name": "turbores",
  "description": "An extremely fast Apple ProRes video decoder",
  "author": "Vanilagy",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "package.json",
    "LICENSE",
    "dist"
  ],
  "license": "MPL-2.0",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vanilagy/turbores.git"
  },
  "bugs": {
    "url": "https://github.com/Vanilagy/turbores/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/Vanilagy"
  },
  "scripts": {
    "dev": "vite",
    "build": "./scripts/build.sh",
    "check": "tsc --noEmit -p src && tsc -p tests",
    "check-docblocks": "tsx scripts/check-docblocks.ts dist/index.d.ts",
    "lint": "zig fmt --check src/index.zig && eslint .",
    "test": "./scripts/build-zig.sh && vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@types/node": "^25.9.2",
    "eslint": "^9.22.0",
    "mediabunny": "^1.25.8",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.2.7",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.62.1"
  },
  "keywords": [
    "prores",
    "apple",
    "decoder",
    "wasm",
    "webassembly",
    "mediabunny"
  ]
}
