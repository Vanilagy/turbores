{
  "name": "prores-decoder",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "package.json",
    "LICENSE",
    "dist"
  ],
  "license": "MPL-2.0",
